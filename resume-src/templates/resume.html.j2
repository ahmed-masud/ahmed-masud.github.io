<!DOCTYPE html>
<html lang="en" data-theme="access">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ name }} — {{ role }}. Tailored application for {{ company }}.">
  <meta name="author" content="{{ name }}">
  <meta name="robots" content="noindex, nofollow">
  <title>{{ name }} — {{ role }} · {{ company }}</title>
  <link rel="stylesheet" href="{{ css_root }}/fonts.css">
  <link rel="stylesheet" href="{{ css_root }}/style.css">
  <link rel="stylesheet" href="{{ css_root }}/resume.css">
  <link rel="icon" type="image/x-icon" href="{{ icon_root }}/favicon.ico">
  <style>
    .tailored-banner {
      background: var(--fg);
      color: var(--bg);
      text-align: center;
      padding: 0.5rem 1rem;
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }
    .tailored-banner a {
      color: rgba(255,255,255,0.6);
      text-decoration: none;
      margin-left: 1.5rem;
    }
    .tailored-banner a:hover { color: #fff; }
    @media print { .tailored-banner { display: none; } }

    /* ── Term tooltips ───────────────────────────────────────────── */
    .term {
      cursor: help;
      text-decoration: underline dotted;
      text-decoration-color: var(--mid);
      text-underline-offset: 3px;
      transition: text-decoration-color 0.15s;
    }
    .term:hover, .term.pinned { text-decoration-color: var(--accent); }
    #term-tooltip {
      display: none;
      position: fixed;
      z-index: 9999;
      max-width: 300px;
      background: var(--bg2);
      border: 1px solid var(--accent);
      border-radius: 3px;
      padding: 0.55rem 0.75rem;
      box-shadow: 0 4px 16px rgba(0,0,0,0.25);
      pointer-events: none;
    }
    #term-tooltip b {
      display: block;
      font-family: var(--mono);
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      color: var(--accent);
      margin-bottom: 0.3rem;
    }
    #term-tooltip p {
      font-family: var(--sans);
      font-size: 12px;
      line-height: 1.6;
      color: var(--mid);
      margin: 0;
    }
    #term-tooltip.visible { display: block; }
    @media print {
      .term { text-decoration: none; }
      #term-tooltip { display: none !important; }
    }
  </style>
</head>
<body>

<div id="theme-announce" aria-live="polite" aria-atomic="true" style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0);"></div>

<div class="theme-bar" role="toolbar" aria-label="Theme selector">
  <span class="theme-bar-label" id="theme-label">Theme:</span>
  <button class="theme-btn" aria-pressed="false" data-theme-name="moody" aria-describedby="theme-label">Moody</button>
  <button class="theme-btn" aria-pressed="false" data-theme-name="dark" aria-describedby="theme-label">Dark</button>
  <button class="theme-btn" aria-pressed="false" data-theme-name="light" aria-describedby="theme-label">Light</button>
  <button class="theme-btn access-btn" aria-pressed="true" data-theme-name="access" aria-describedby="theme-label">High Contrast</button>
</div>

<div class="tailored-banner">
  Prepared for {{ company }} — {{ role }} · {{ date_display }}
  <a href="../../resume.html">← Master resume</a>
</div>

<a class="skip-link" href="#main-content">Skip to main content</a>

<header role="banner" class="resume-header">
  <div class="resume-header-inner">
    <div class="resume-header-left">
      <h1>{{ name }}</h1>
      <p class="resume-title">{{ title }}</p>
      <p class="resume-location">{{ location }}</p>
    </div>
    <div class="resume-header-right">
      <a href="mailto:{{ contact.email }}">{{ contact.email }}</a>
      <a href="tel:+1{{ contact.phone | replace('(','') | replace(')','') | replace(' ','') | replace('-','') }}">{{ contact.phone }}</a>
      <a href="https://{{ contact.linkedin }}" target="_blank" rel="noopener noreferrer">{{ contact.linkedin }}</a>
      <a href="https://{{ contact.website }}" target="_blank" rel="noopener noreferrer">{{ contact.website }}</a>
    </div>
  </div>
  <nav class="resume-nav" aria-label="Resume navigation">
    <a href="../../resume.html">← Master resume</a>
    <button class="print-btn" onclick="window.print()" aria-label="Print or save as PDF">Print / Save PDF</button>
  </nav>
</header>

<main id="main-content" class="resume-main">

{% for section in sections %}
{% if not loop.first %}
  <hr class="resume-rule">
{% endif %}

{# ── Summary ── #}
{% if section == 'summary' %}
  <section class="resume-section" aria-labelledby="summary-heading">
    <h2 id="summary-heading" class="section-title">Summary</h2>
    <p class="summary-text">{{ summary | tokens }}</p>
    {% if highlights %}
    <div class="summary-highlights" role="list" aria-label="Key highlights">
      {% for h in highlights %}
      <span role="listitem" class="highlight">{{ h }}</span>
      {% endfor %}
    </div>
    {% endif %}
  </section>

{# ── Skills ── #}
{% elif section == 'skills' %}
  <section class="resume-section" aria-labelledby="skills-heading">
    <h2 id="skills-heading" class="section-title">Technical Skills</h2>
    <div class="skills-grid">
      {% for label, items in skills.items() %}
      <div class="skill-row">
        <dt>{{ label }}</dt>
        <dd>{{ items }}</dd>
      </div>
      {% endfor %}
    </div>
  </section>

{# ── Experience ── #}
{% elif section == 'experience' %}
  <section class="resume-section" aria-labelledby="experience-heading">
    <h2 id="experience-heading" class="section-title">Experience</h2>
    {% for job in experience %}
    {% set exp_id = "job-" ~ job.id %}
    {% set is_open = loop.index <= expand_first_n %}
    <div class="job">
      <button class="job-header" aria-expanded="{{ 'true' if is_open else 'false' }}" aria-controls="{{ exp_id }}">
        <div class="job-meta">
          <span class="job-role">{{ job.title }}</span>
          <span class="job-company">{{ job.company }}</span>
        </div>
        <span class="job-dates">{{ job.dates }}</span>
      </button>
      <div class="job-body" id="{{ exp_id }}"{% if not is_open %} hidden{% endif %}>
        {% if job.desc %}<p class="job-desc">{{ job.desc | tokens }}</p>{% endif %}
        {% if job.bullets %}
        <ul class="job-bullets">
          {% for bullet in job.bullets %}
          <li>{{ bullet | md_inline | safe }}</li>
          {% endfor %}
        </ul>
        {% endif %}
      </div>
    </div>
    {% endfor %}
  </section>

{# ── Patents & Recognition ── #}
{% elif section == 'patents' %}
  <section class="resume-section" aria-labelledby="patents-heading">
    <h2 id="patents-heading" class="section-title">Patents &amp; Recognition</h2>
    {% for p in patents %}
    <div class="patent-entry">
      <p class="patent-id">US Patent {{ p.number }} · Issued {{ p.issued }} · Assignee: {{ p.assignee }}</p>
      <p class="patent-title">{{ p.title }}</p>
      <p class="patent-desc">{{ p.desc | tokens }}</p>
    </div>
    {% endfor %}
    {% if awards %}
    <div class="awards-list" role="list">
      {% for a in awards %}
      <div class="award-entry" role="listitem">
        <span class="award-year">{{ a.year }}</span>
        <div><strong>{{ a.title }}</strong> — {{ a.detail }}</div>
      </div>
      {% endfor %}
    </div>
    {% endif %}
  </section>

{# ── Education ── #}
{% elif section == 'education' %}
  <section class="resume-section" aria-labelledby="education-heading">
    <h2 id="education-heading" class="section-title">Education &amp; Certifications</h2>
    <div class="edu-list">
      {% for e in education %}
      <div class="edu-entry">
        <span class="edu-degree">{{ e.degree }}</span>
        <span class="edu-school">{{ e.school }}</span>
        <span class="edu-dates">{{ e.dates }}</span>
        {% if e.note %}<span class="edu-note">{{ e.note }}</span>{% endif %}
      </div>
      {% endfor %}
    </div>
    {% if certifications %}
    <div class="cert-list">
      <p class="cert-label">Certifications</p>
      <p class="cert-items">
        {%- for cert in certifications -%}
          {{ cert }}{% if not loop.last %} &nbsp;·&nbsp; {% endif %}
        {%- endfor -%}
      </p>
    </div>
    {% endif %}
  </section>

{# ── Security Clearances ── #}
{% elif section == 'clearances' %}
  <section class="resume-section clearance-section" aria-labelledby="clearance-heading">
    <h2 id="clearance-heading" class="section-title">Security Clearance</h2>
    <p>{{ clearances | tokens }}</p>
  </section>

{% endif %}
{% endfor %}

</main>

<footer role="contentinfo" class="resume-footer">
  <p>{{ name }} · Ottawa, ON · <a href="mailto:{{ contact.email }}">{{ contact.email }}</a> · {{ contact.phone }}</p>
  <p><a href="https://{{ contact.website }}">{{ contact.website }}</a> · Prepared for {{ company }} · {{ date_display }}</p>
</footer>

<div id="term-tooltip" role="tooltip" aria-live="polite"></div>

<script>
/* ── Term tooltip engine ──────────────────────────────────────────────────── */
(function () {
  var DEFS = {
    'TOGAF':                 'The Open Group Architecture Framework — structured methodology for aligning IT strategy with business goals across an enterprise.',
    'SABSA':                 'Sherwood Applied Business Security Architecture — risk-driven security architecture framework designed to layer over TOGAF.',
    'NIST 800-53':           'NIST Special Publication 800-53 — US federal security control catalogue covering 20 control families for government systems at Moderate and High impact levels.',
    'OAuth2/OIDC/SAML':      'Identity federation protocols. OAuth2: delegated authorisation. OIDC: authentication layer on OAuth2. SAML: XML-based enterprise single sign-on.',
    'FedRAMP':               'Federal Risk and Authorization Management Program — US government cloud security authorisation standard required for any cloud service handling federal data.',
    'CMMC':                  'Cybersecurity Maturity Model Certification — US DoD contractor supply chain security standard, Levels 1–3.',
    'PKI':                   'Public Key Infrastructure — system for issuing, distributing, and managing X.509 digital certificates and asymmetric cryptography.',
    'CSI drivers':           'Container Storage Interface — Kubernetes plugin standard for attaching and managing storage volumes in containerised workloads.',
    'Neo4j':                 'Leading property-graph database using the Cypher query language. Used in Trustifier for identity relationship graphs and in Resiliate for policy dependency tracking (~2 years production use).',
    'Multigraphs':           'Graphs that allow multiple distinct edges between the same pair of nodes — e.g. a user that has both an \'owns\' and a \'manages\' edge to the same resource. Natively supported in Neo4j.',
    'GraphRAG pipelines':    'Retrieval-Augmented Generation over a knowledge graph rather than a flat vector index. Enables multi-hop reasoning across entity relationships, outperforming pure vector search for structured queries.',
    'LangChain / LangGraph': 'Python frameworks for LLM application development. LangChain: tool-use, retrieval chains, prompt management. LangGraph: stateful multi-agent workflows modelled as directed graphs.',
    'Vector databases':      'Databases optimised for storing and querying high-dimensional embedding vectors, enabling semantic similarity search. Examples: Pinecone, Weaviate, pgvector. Different from graph databases.',
    'Embeddings':            'Dense numerical vector representations of text or data produced by neural encoder models. Similar inputs cluster in vector space, enabling semantic search. Entirely distinct from embedded computing — see the Embedded row.',
    'Agentic workflows':     'AI architectures where an LLM autonomously plans multi-step tasks, calls external tools, observes results, and iterates — rather than producing a single response.',
    'Databricks':            'Unified analytics platform built on Apache Spark. Supports large-scale data engineering, ML training pipelines, and LLM fine-tuning workflows.',
    'FreeRTOS':              'Open-source real-time operating system kernel for microcontrollers. Provides task scheduling and timing guarantees in resource-constrained hardware. Used in UAV signal processing for Allied Forces/NATO.',
    'Cortex-M':              'ARM processor core family for microcontrollers — low-power, hard real-time capable. M4/M7 variants add hardware floating-point for DSP workloads.',
  };

  /* Sort longest-first to avoid partial matches (e.g. "Embeddings" before "Embedded") */
  var terms = Object.keys(DEFS).sort(function (a, b) { return b.length - a.length; });

  function esc(s) { return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'); }

  function annotateDD(dd) {
    var html = dd.innerHTML;
    terms.forEach(function (term) {
      if (html.indexOf(term) === -1) return;
      var re  = new RegExp('(?<![\\w/-])' + esc(term) + '(?![\\w/-])', 'g');
      var def = DEFS[term].replace(/"/g, '&quot;');
      html = html.replace(re, '<span class="term" data-def="' + def + '">' + term + '</span>');
    });
    dd.innerHTML = html;
  }

  /* Annotate "Embedded" dt label with disambiguation tooltip */
  document.querySelectorAll('.skills-grid dt').forEach(function (dt) {
    if (dt.textContent.trim() === 'Embedded') {
      dt.innerHTML = '<span class="term" data-def="Bare-metal and real-time OS (RTOS) programming for microcontrollers, DSPs, and purpose-built hardware. Entirely distinct from AI &apos;embeddings&apos; (dense vector representations used in machine learning) — see Graph &amp; AI row.">Embedded</span>';
    }
  });

  document.querySelectorAll('.skills-grid dd').forEach(annotateDD);

  /* ── Tooltip behaviour ───────────────────────────────────────── */
  var tip    = document.getElementById('term-tooltip');
  var pinned = null;

  function render(el) {
    tip.innerHTML = '<b>' + el.textContent.trim() + '</b><p>' + el.dataset.def + '</p>';
  }
  function place(x, y) {
    var w = tip.offsetWidth, h = tip.offsetHeight;
    var left = x + 16, top = y + 16;
    if (left + w > window.innerWidth  - 8) left = x - w - 8;
    if (top  + h > window.innerHeight - 8) top  = y - h - 8;
    tip.style.left = left + 'px';
    tip.style.top  = top  + 'px';
  }
  function show(el, x, y) { render(el); tip.classList.add('visible'); place(x, y); }
  function hide()          { tip.classList.remove('visible'); }

  function wire(el) {
    el.addEventListener('mouseenter', function (e) { if (pinned !== el) show(el, e.clientX, e.clientY); });
    el.addEventListener('mousemove',  function (e) { if (pinned !== el) place(e.clientX, e.clientY); });
    el.addEventListener('mouseleave', function ()  { if (pinned !== el) hide(); });
    el.addEventListener('click', function (e) {
      e.stopPropagation();
      if (pinned === el) { pinned = null; el.classList.remove('pinned'); hide(); }
      else { if (pinned) pinned.classList.remove('pinned'); pinned = el; el.classList.add('pinned'); show(el, e.clientX, e.clientY); }
    });
  }

  document.querySelectorAll('.term').forEach(wire);
  document.addEventListener('click',   function ()  { if (pinned) { pinned.classList.remove('pinned'); pinned = null; } hide(); });
  document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && pinned) { pinned.classList.remove('pinned'); pinned = null; hide(); } });
}());
</script>

<script>
(function () {
  document.querySelectorAll('.job-header').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var expanded = btn.getAttribute('aria-expanded') === 'true';
      var body = document.getElementById(btn.getAttribute('aria-controls'));
      btn.setAttribute('aria-expanded', !expanded);
      if (expanded) { body.hidden = true; } else { body.hidden = false; }
    });
  });
  window.addEventListener('beforeprint', function () {
    document.querySelectorAll('.job-header').forEach(function (btn) {
      btn.setAttribute('aria-expanded', 'true');
      var body = document.getElementById(btn.getAttribute('aria-controls'));
      if (body) body.hidden = false;
    });
  });
})();
</script>

<script>
(function () {
  var root = document.documentElement;
  var announce = document.getElementById("theme-announce");
  var themeNames = { moody:"Moody", dark:"Dark", light:"Light", access:"High Contrast accessibility" };
  function setTheme(theme) {
    root.setAttribute("data-theme", theme);
    document.querySelectorAll(".theme-btn").forEach(function (btn) {
      btn.setAttribute("aria-pressed", btn.dataset.themeName === theme ? "true" : "false");
    });
    if (announce) {
      announce.textContent = themeNames[theme] + " theme applied";
      setTimeout(function () { announce.textContent = ""; }, 2000);
    }
    try { localStorage.setItem("am-theme", theme); } catch (e) {}
  }
  document.querySelectorAll(".theme-btn").forEach(function (btn) {
    btn.addEventListener("click", function () { setTheme(btn.dataset.themeName); });
  });
  try {
    var saved = localStorage.getItem("am-theme");
    if (saved && themeNames[saved]) { setTheme(saved); return; }
  } catch (e) {}
  try {
    if (window.matchMedia("(prefers-color-scheme: light)").matches) { setTheme("light"); }
  } catch (e) {}
}());
</script>
</body>
</html>
