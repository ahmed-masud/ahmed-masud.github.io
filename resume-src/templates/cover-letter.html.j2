<!DOCTYPE html>
<html lang="en" data-theme="access">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ name }} — Cover Letter for {{ company }} {{ role }}.">
  <meta name="author" content="{{ name }}">
  <meta name="robots" content="noindex, nofollow">
  <title>{{ name }} — Cover Letter · {{ company }}</title>
  <link rel="stylesheet" href="{{ css_root }}/fonts.css">
  <link rel="stylesheet" href="{{ css_root }}/style.css">
  <link rel="stylesheet" href="{{ css_root }}/resume.css">
  <link rel="icon" type="image/x-icon" href="{{ icon_root }}/favicon.ico">
  <style>
    .tailored-banner {
      background: var(--fg);
      color: var(--bg);
      text-align: center;
      padding: 0.5rem 1rem;
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }
    .tailored-banner a {
      color: rgba(255,255,255,0.6);
      text-decoration: none;
      margin-left: 1.5rem;
    }
    .tailored-banner a:hover { color: #fff; }

    .cl-main {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 3rem 3rem 2rem;
    }
    .cl-date {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--faint);
      margin-bottom: 2.5rem;
    }
    .cl-salutation {
      font-size: 0.95rem;
      color: var(--fg);
      margin-bottom: 1.5rem;
    }
    .cl-body p {
      font-size: 0.95rem;
      color: var(--mid);
      line-height: 1.9;
      margin-bottom: 1.4rem;
    }
    .cl-body p strong { color: var(--fg); font-weight: 500; }
    .cl-body p a { color: var(--accent); }
    .cl-sig {
      margin-top: 2rem;
      font-family: var(--serif);
      font-size: 1.3rem;
      font-weight: 500;
      color: var(--fg);
    }
    .cl-sig-detail {
      font-family: var(--mono);
      font-size: 10px;
      color: var(--faint);
      margin-top: 0.3rem;
      line-height: 1.8;
    }
    .cl-sig-detail a { color: var(--accent); text-decoration: none; }
    .cl-nav {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 0 3rem 1rem;
      display: flex;
      gap: 1.5rem;
      font-family: var(--mono);
      font-size: 10px;
    }
    .cl-nav a { color: var(--faint); text-decoration: none; }
    .cl-nav a:hover { color: var(--fg); }

    @media (max-width: 640px) {
      .cl-main { padding: 2rem 1.5rem 1.5rem; }
      .cl-nav  { padding: 0 1.5rem 1rem; }
    }
    @media print {
      .tailored-banner, .cl-nav, .print-btn { display: none !important; }
      .cl-main { padding: 1rem 0 0; }
      .cl-body p { font-size: 10.5pt; line-height: 1.75; }
    }
  </style>
</head>
<body>

<div id="theme-announce" aria-live="polite" aria-atomic="true" style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0);"></div>

<div class="theme-bar" role="toolbar" aria-label="Theme selector">
  <span class="theme-bar-label" id="theme-label">Theme:</span>
  <button class="theme-btn" aria-pressed="false" data-theme-name="moody" aria-describedby="theme-label">Moody</button>
  <button class="theme-btn" aria-pressed="false" data-theme-name="dark" aria-describedby="theme-label">Dark</button>
  <button class="theme-btn" aria-pressed="false" data-theme-name="light" aria-describedby="theme-label">Light</button>
  <button class="theme-btn access-btn" aria-pressed="true" data-theme-name="access" aria-describedby="theme-label">High Contrast</button>
</div>

<div class="tailored-banner">
  Cover Letter — {{ company }} · {{ role }} · {{ date_display }}
  <a href="resume.html">← Resume</a>
  <a href="../../resume.html">← Master resume</a>
</div>

<a class="skip-link" href="#main-content">Skip to main content</a>

<header role="banner" class="resume-header">
  <div class="resume-header-inner">
    <div class="resume-header-left">
      <h1>{{ name }}</h1>
      <p class="resume-title">{{ title }}</p>
      <p class="resume-location">{{ location }}</p>
    </div>
    <div class="resume-header-right">
      <a href="mailto:{{ contact.email }}">{{ contact.email }}</a>
      <a href="tel:+1{{ contact.phone | replace('(','') | replace(')','') | replace(' ','') | replace('-','') }}">{{ contact.phone }}</a>
      <a href="https://{{ contact.linkedin }}" target="_blank" rel="noopener noreferrer">{{ contact.linkedin }}</a>
      <a href="https://{{ contact.website }}" target="_blank" rel="noopener noreferrer">{{ contact.website }}</a>
    </div>
  </div>
  <nav class="resume-nav" aria-label="Document navigation">
    <a href="resume.html">← Resume</a>
    <button class="print-btn" onclick="window.print()" aria-label="Print or save as PDF">Print / Save PDF</button>
  </nav>
</header>

<main id="main-content">
  <div class="cl-main">
    <p class="cl-date">{{ cl_date_display }}</p>
    <p class="cl-salutation">{{ cl_salutation }}</p>
    <div class="cl-body">
      {{ cl_body | md | safe }}
    </div>
    <p class="cl-sig">{{ name }}</p>
    <div class="cl-sig-detail">
      <a href="mailto:{{ contact.email }}">{{ contact.email }}</a><br>
      {{ contact.phone }}<br>
      <a href="https://{{ contact.website }}/resume/{{ job_id }}/">{{ contact.website }}/resume/{{ job_id }}/</a>
    </div>
  </div>
</main>

<div class="cl-nav" aria-label="Application navigation">
  <a href="resume.html">Resume →</a>
  <a href="../../resume.html">Master resume →</a>
</div>

<footer role="contentinfo" class="resume-footer">
  <p>{{ name }} · Ottawa, ON · <a href="mailto:{{ contact.email }}">{{ contact.email }}</a></p>
  <p><a href="https://{{ contact.website }}">{{ contact.website }}</a> · Prepared for {{ company }} · {{ date_display }}</p>
</footer>

<script>
(function () {
  var root = document.documentElement;
  var announce = document.getElementById("theme-announce");
  var themeNames = { moody:"Moody", dark:"Dark", light:"Light", access:"High Contrast accessibility" };
  function setTheme(theme) {
    root.setAttribute("data-theme", theme);
    document.querySelectorAll(".theme-btn").forEach(function (btn) {
      btn.setAttribute("aria-pressed", btn.dataset.themeName === theme ? "true" : "false");
    });
    if (announce) {
      announce.textContent = themeNames[theme] + " theme applied";
      setTimeout(function () { announce.textContent = ""; }, 2000);
    }
    try { localStorage.setItem("am-theme", theme); } catch (e) {}
  }
  document.querySelectorAll(".theme-btn").forEach(function (btn) {
    btn.addEventListener("click", function () { setTheme(btn.dataset.themeName); });
  });
  try {
    var saved = localStorage.getItem("am-theme");
    if (saved && themeNames[saved]) { setTheme(saved); return; }
  } catch (e) {}
  try {
    if (window.matchMedia("(prefers-color-scheme: light)").matches) { setTheme("light"); }
  } catch (e) {}
}());
</script>
</body>
</html>
